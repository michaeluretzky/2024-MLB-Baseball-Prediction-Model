import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense
from sklearn.preprocessing import MinMaxScaler

def load_data(file_paths, player_type):
    try:
        players = pd.read_excel(file_paths[player_type.lower()])
        players['Year'] = players['Year'].astype(int)  # Ensure 'Year' is an integer
        players = players[players['Year'] != 2024]  # Exclude incomplete 2024 data
        return players
    except Exception as e:
        print(f"Failed to load data: {e}")
        return None

def get_player_data(players, player_name):
    player_data = players[players['Player'].str.lower() == player_name.lower()]
    if player_data.empty:
        return None, f"No data found for {player_name}."

    # Ensure 'Year' is treated as an integer and not included in numeric calculations
    player_data['Year'] = player_data['Year'].astype(int)  # Convert 'Year' to integer if not already
    numeric_columns = [col for col in player_data.columns if player_data[col].dtype in [np.float64, np.int64]]
    if 'Year' in numeric_columns:
        numeric_columns.remove('Year')

    player_data = player_data.groupby('Year')[numeric_columns].mean().reset_index()
    return player_data, None

def predict_future_performance(player_data, category):
    scaler = MinMaxScaler()
    years = player_data['Year'].values.reshape(-1, 1)
    stats = player_data[category].values.reshape(-1, 1)
    years_scaled = scaler.fit_transform(years)
    model = Sequential([
        Dense(64, input_dim=1, activation='relu'),
        Dense(64, activation='relu'),
        Dense(1)
    ])
    model.compile(optimizer='adam', loss='mse', metrics=['mse'])
    model.fit(years_scaled, stats, epochs=1000, verbose=1)
    year_2024_scaled = scaler.transform(np.array([[2024]]))
    predicted_value = model.predict(year_2024_scaled)[0][0]
    return predicted_value

def plot_data(player_stats, category, player_name, predicted_2024):
    plt.figure(figsize=(10, 5))
    plt.plot(player_stats['Year'], player_stats[category], 'b-o', label=f'Historical {category}', linewidth=2)
    if predicted_2024 is not None:
        plt.scatter([2024], [predicted_2024], color='red', zorder=5, label=f'Predicted {category} in 2024: {predicted_2024:.2f}')
        plt.plot(np.append(player_stats['Year'].values, 2024), np.append(player_stats[category].values, predicted_2024), 'b--', label='Projection', linewidth=1)
    plt.xlabel("Year")
    plt.ylabel(category)
    plt.title(f"{category} Historical Data and 2024 Prediction for {player_name}")
    plt.legend()
    plt.grid(True)
    plt.show()

def main():
    file_paths = {
        'hitter': 'allhitters.xlsx',
        'pitcher': 'allpitchers.xlsx'
    }
    player_type = input("Enter the player type ('Hitter' or 'Pitcher'): ").lower()
    players = load_data(file_paths, player_type)
    if players is None:
        return
    player_name = input("Enter the player's name: ")
    player_stats, error = get_player_data(players, player_name)
    if error:
        print(error)
        return

    choice = input("Do you want to plot a specific statistic or see a table of all predicted 2024 statistics? (plot/table): ")
    if choice == 'plot':
        category = input("Enter a statistic to plot (e.g., 'HR', 'BA' for batters, 'ERA', 'SO' for pitchers): ")
        predicted_2024 = predict_future_performance(player_stats, category)
        plot_data(player_stats, category, player_name, predicted_2024)
    elif choice == 'table':
        display_full_predictions(player_stats, player_name)

def display_full_predictions(player_stats, player_name):
    print(f"\nFull Predicted Statistics for 2024 for {player_name}:")
    predictions = {'Statistic': [], 'Predicted Value': []}
    for column in player_stats.columns:
        if column != 'Year' and player_stats[column].dtype != 'object':
            predicted_value = predict_future_performance(player_stats, column)
            predictions['Statistic'].append(column)
            predictions['Predicted Value'].append(f"{predicted_value:.2f}")
    predictions_df = pd.DataFrame(predictions)
    print(predictions_df.to_string(index=False))

if __name__ == "__main__":
    main()
